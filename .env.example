# GROQ_API_KEY: Required for Groq Llama Cloud API calls.
# Obtain your free API Key at: https://console.groq.com/
# Users configure this via the Secrets panel or env vars.

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_CONFIGURATION: Enter your Supabase credentials to persist data in the cloud!
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# AI_PROVIDER: Select between 'groq' | 'ollama'
AI_PROVIDER=groq

# OLLAMA CONFIGURATION (Local Free Llama)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3"

# GROQ CLOUD CONFIGURATION (Cloud Llama)
# Obtain your free API Key at: https://console.groq.com/
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"


